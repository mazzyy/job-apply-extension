{
  "manifest_version": 3,
  "name": "Job Apply Assistant",
  "version": "0.13.0",
  "description": "Analyze job fit, autofill applications, and track every role you apply to — across LinkedIn, Greenhouse, Lever, Ashby and custom career sites.",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://*.sapsf.eu/*",
    "https://*.sapsf.com/*",
    "https://*.successfactors.com/*",
    "https://*.successfactors.eu/*",
    "https://www.linkedin.com/*",
    "https://*.greenhouse.io/*",
    "https://boards.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://jobs.lever.co/*",
    "https://jobs.ashbyhq.com/*",
    "https://*.ashbyhq.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.workday.com/*",
    "https://*/*",
    "http://*/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_title": "Job Apply Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content/autofill.js",
        "content/overlay.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.linkedin.com/jobs/view/*",
        "https://www.linkedin.com/jobs/collections/*",
        "https://www.linkedin.com/jobs/search/*"
      ],
      "js": [
        "content/linkedin.js",
        "content/apply_watcher.js",
        "content/question_suggest.js",
        "content/linkedin_easyapply.js"
      ],
      "css": [
        "content/overlay.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://boards.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://job-boards.eu.greenhouse.io/*"
      ],
      "js": [
        "content/autofill.js",
        "content/apply_watcher.js",
        "content/greenhouse.js",
        "content/question_suggest.js"
      ],
      "css": [
        "content/overlay.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.lever.co/*",
        "https://jobs.lever.co/*"
      ],
      "js": [
        "content/autofill.js",
        "content/apply_watcher.js",
        "content/lever.js",
        "content/question_suggest.js"
      ],
      "css": [
        "content/overlay.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://jobs.ashbyhq.com/*",
        "https://*.ashbyhq.com/*"
      ],
      "js": [
        "content/autofill.js",
        "content/apply_watcher.js",
        "content/ashby.js",
        "content/question_suggest.js"
      ],
      "css": [
        "content/overlay.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.successfactors.eu/*",
        "https://*.successfactors.com/*",
        "https://*.sapsf.com/*",
        "https://*.sapsf.eu/*"
      ],
      "js": [
        "content/autofill.js",
        "content/apply_watcher.js",
        "content/successfactors.js",
        "content/question_suggest.js"
      ],
      "css": [
        "content/overlay.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/autofill.js",
        "content/apply_watcher.js",
        "content/generic.js",
        "content/question_suggest.js"
      ],
      "css": [
        "content/overlay.css"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "exclude_matches": [
        "https://www.linkedin.com/*",
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://jobs.ashbyhq.com/*",
        "https://*.ashbyhq.com/*",
        "https://chrome.google.com/*",
        "https://localhost/*",
        "http://localhost/*",
        "https://*.successfactors.eu/*",
        "https://*.successfactors.com/*",
        "https://*.sapsf.com/*",
        "https://*.sapsf.eu/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}